---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
}

const { title, description, pubDate, slug } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}/`} class="block group">
  <article
    class="border border-neutral-800 rounded-lg p-5 hover:border-neutral-600 transition-colors"
  >
    <time class="text-xs text-neutral-500">{formattedDate}</time>
    <h2 class="text-xl font-semibold mt-1 group-hover:text-neutral-300">
      {title}
    </h2>
    <p class="text-neutral-400 text-sm mt-2">{description}</p>
  </article>
</a>
